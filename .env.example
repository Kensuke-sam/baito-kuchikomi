# ============================================================
# Supabase
# ============================================================
# プロジェクト設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Settings > API > service_role（絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Mapbox
# ============================================================
# https://account.mapbox.com/ からトークン取得
# Public token（フロントエンド用）
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# ============================================================
# 投稿対象エリア設定
# ============================================================
# 必要な場合のみ設定。未設定ならエリア制限は無効
NEXT_PUBLIC_ALLOWED_MIN_LAT=35.7200
NEXT_PUBLIC_ALLOWED_MAX_LAT=35.7900
NEXT_PUBLIC_ALLOWED_MIN_LNG=139.6900
NEXT_PUBLIC_ALLOWED_MAX_LNG=139.7400

# ============================================================
# Resend（メール通知）
# ============================================================
# https://resend.com/ からAPIキー取得
# 未設定でもアプリは動作するが、削除申請などの管理者通知は送られない
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# ============================================================
# サイトURL（本番環境）
# ============================================================
NEXT_PUBLIC_SITE_URL=https://baito-review.com
