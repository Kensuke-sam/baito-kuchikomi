# ============================================================
# Supabase
# ============================================================
# プロジェクト設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Settings > API > service_role（絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Mapbox
# ============================================================
# https://account.mapbox.com/ からトークン取得
# 任意。設定すると Mapbox Geocoding を優先利用する
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# ============================================================
# 収益導線（任意）
# ============================================================
# ASPの提携URLが取れたら置き換える。未設定時は内部ガイドへ遷移
NEXT_PUBLIC_PARTNER_SINGLE_DAY_JOBS_URL=
NEXT_PUBLIC_PARTNER_PART_TIME_JOBS_URL=
NEXT_PUBLIC_PARTNER_CAREER_URL=

# ============================================================
# 計測（任意）
# ============================================================
# GTMを使う場合は NEXT_PUBLIC_GTM_ID を優先。GA4を直接入れる場合だけ NEXT_PUBLIC_GA_MEASUREMENT_ID を使う
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ============================================================
# Resend（メール通知）
# ============================================================
# https://resend.com/ からAPIキー取得
# 未設定でもアプリは動作するが、削除申請などの管理者通知は送られない
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=no-reply@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# ============================================================
# サイトURL（本番環境）
# ============================================================
NEXT_PUBLIC_SITE_URL=https://baito-review.com
